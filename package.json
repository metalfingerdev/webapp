{
	"name": "aggarwalkart",
	"author": "mfdev",
	"version": "0.8.0",
	"license": "MIT",
	"private": true,
	"type": "module",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/aggarwalkart/webapp.git"
	},
	"scripts": {
		"cleanse": "pnpm format && pnpm lint && pnpm check && pnpm test && pnpm build",
		"dev:frontend": "vite dev",
		"dev:backend": "pnpm dlx convex dev",
		"dev": "concurrently --kill-others --prefix-colors \"red,yellow\" --names \"svelte,convex\" \"pnpm dev:frontend\" \"pnpm dev:backend\"",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"test:unit": "vitest run",
		"test": "vitest run"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild"
		],
		"peerDependencyRules": {
			"ignoreMissing": [
				"vite"
			],
			"allowAny": [
				"vite"
			]
		}
	},
	"devDependencies": {
		"@convex-dev/better-auth": "^0.12.2",
		"@convex-dev/eslint-plugin": "^2.0.0",
		"@eslint/compat": "^2.1.0",
		"@eslint/js": "^10.0.1",
		"@sveltejs/adapter-vercel": "^5.10.2",
		"@sveltejs/kit": "^2.64.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/vite": "^4.3.0",
		"@types/node": "^25.9.2",
		"@types/pdfmake": "^0.3.3",
		"@vitest/browser": "^4.1.8",
		"better-auth": "1.6.15",
		"concurrently": "^10.0.3",
		"convex": "1.40.0",
		"convex-svelte": "^0.13.0",
		"eslint": "^10.4.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.19.0",
		"globals": "^17.6.0",
		"jsdom": "^29.1.1",
		"playwright": "^1.61.1",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^4.1.0",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"svelte": "^5.56.3",
		"svelte-check": "^4.6.0",
		"svelte-eslint-parser": "^1.8.0",
		"tailwindcss": "^4.3.0",
		"tsx": "^4.22.4",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.61.0",
		"vite": "^8.0.16",
		"vite-plugin-devtools-json": "^1.0.0",
		"vitest": "^4.1.8",
		"vitest-browser-svelte": "^2.1.1"
	},
	"dependencies": {
		"@klinking/squircle": "^0.9.0",
		"@lucide/svelte": "^1.23.0",
		"bits-ui": "^2.18.1",
		"is-network-error": "^1.3.2",
		"paneforge": "^1.0.2",
		"pdfmake": "^0.3.11",
		"razorpay": "^2.9.6",
		"resend": "^6.16.0",
		"xlsx": "^0.18.5"
	}
}
