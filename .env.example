# Copy to .env.local and fill in your Convex deployment values.
# The PUBLIC_ vars are exposed to the browser AND required at build time.

# Convex deployment URL (e.g. https://your-deployment.convex.cloud)
PUBLIC_CONVEX_URL=

# Convex site URL used by the auth handler (e.g. https://your-deployment.convex.site)
PUBLIC_CONVEX_SITE_URL=

# Convex deployment name, used by the Convex CLI / `convex dev`
CONVEX_DEPLOYMENT=
